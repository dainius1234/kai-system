FROM python:3.11-slim

WORKDIR /app

COPY agentic/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

RUN addgroup --system app && adduser --system --ingroup app app

COPY agentic/introspect_app.py ./
COPY agentic/kai_config.py ./
COPY agentic/security_audit.py ./
COPY common/ ./common/

EXPOSE 8023

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8023/health')" || exit 1

USER app

CMD ["python", "introspect_app.py"]

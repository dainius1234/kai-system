# ── Sovereign AI — Environment Variables ──────────────────────────
# Copy to .env and fill in real values before deploying.

# Core infrastructure
SOVEREIGN_ENV=dev                        # dev | prod (controls strictness)
DB_PASSWORD=change-me
PG_URI=postgresql://keeper:change-me@postgres:5432/sovereign
VECTOR_STORE=turbovec                    # memory | postgres | turbovec
# TurboVec ANN index settings (only used when VECTOR_STORE=turbovec)
TURBOVEC_INDEX_PATH=/data/turbovec/memories.tv   # path inside the container; mount a named volume here
TURBOVEC_BITS=4                          # quantization bits for IdMapIndex (4 = default, 8 = higher recall)

# Notifications — route through local gateway, NOT direct cloud
NOTIFY_URL=                              # e.g. http://perception-telegram:9000/alert
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Network / VPN
TS_AUTHKEY=tskey-example
TAILSCALE_IP=100.64.0.1
PORT=2222

# Inter-service HMAC auth
INTERSERVICE_HMAC_SECRET=change-me-in-production
INTERSERVICE_HMAC_SECRET_PREV=
INTERSERVICE_HMAC_KEY_ID=v1
INTERSERVICE_HMAC_KEY_ID_PREV=v0
INTERSERVICE_HMAC_REVOKED_IDS=
INTERSERVICE_HMAC_STRICT_KEY_ID=false
TOOL_GATE_DUAL_SIGN=false

# Secrets / Vault
BRIDGE_SHARED_SECRET=
VAULT_ROOT_TOKEN=
VAULT_UNSEAL_KEY=
TPM_UNSEAL_CMD=
GRAFANA_ADMIN_PASSWORD=admin

# Self-employment advisor (UK-focused)
MTD_START=50000
VAT_THRESHOLD=85000
MILEAGE_RATE=0.45
SELF_EMP_ROOT=/data/self-emp

# ── GPU & LLM Configuration ──────────────────────────────────────────
# Hardware control
FORCE_CPU=false                          # Set true to force CPU-only mode

# Base model selection
OLLAMA_MODEL=qwen2.5:0.5b                # Default CPU-safe model
# GPU-ready options: qwen2.5:7b, qwen2.5:14b, llama3.3:70b, deepseek-coder-v2:6.7b
EMBEDDING_OLLAMA_MODEL=all-minilm        # memu-graph (Cognee) embedding model — must be an
                                          # Ollama-recognized embedding-capable model, not a chat
                                          # model; see EMBEDDING_DIMENSIONS in docker-compose.full.yml

# Specialist endpoint overrides (fusion consensus routing)
LLM_DEEPSEEK_URL=                        # e.g. http://ollama:11434 (code-heavy tasks)
LLM_DOLPHIN_URL=                         # e.g. http://ollama:11434 (general conversation)
LLM_KIMI_URL=                            # e.g. http://ollama:11434 (reasoning tasks)

# Speculative decoding (GPU acceleration)
ENABLE_SPECULATIVE_DECODING=false        # Enable when GPU hardware is available
SPECULATIVE_DRAFT_MODEL=qwen2.5:0.5b     # Fast draft model
SPECULATIVE_DRAFT_TOKENS=5               # Tokens drafted ahead
SPECULATIVE_VERIFY_MODEL=qwen2.5:7b      # Verification model

# ── Wake-word + Intent Judge (J2) ──────────────────────────
WAKE_WORDS=kai,hey kai,ok kai
WAKE_COOLDOWN_SECONDS=2
WAKE_INTENT_MODEL=qwen2:0.5b
WAKE_CONFIDENCE_THRESHOLD=0.6

# ── Memory retrieval cap (H2.2) ──────────────────────────────
# Maximum candidate records fetched per retrieve_ranked() call before
# scoring.  Keeps retrieval O(cap) instead of O(store-size).  Increase
# if you need deeper recall over a very large memory store.
MEMU_MAX_CANDIDATES=500

# ── Chassis polish (C2 / C5 / C9) ──────────────────────────────────
# C2: kill streaming if no token arrives within N seconds (0 = disabled)
STREAM_HEARTBEAT_TIMEOUT=30
# C5: seconds to cache Ollama /api/tags response (avoids hammering Ollama)
MODEL_TAGS_CACHE_TTL=60
# C9: send a warm prompt on startup to pre-load the model into RAM
LLM_WARMUP_ENABLED=true
# C9: automatically pull the model on startup if it isn't in Ollama yet
OLLAMA_AUTO_PULL=false

# ── P29 CIS Financial Awareness ──────────────────────────────────────
# Persistent data root for CIS records and finance data
FINANCE_ROOT=/data/finance

# ── Graph fan-out (memu-core → memu-graph) ───────────────────────────
# Enable write-side fan-out: every memorize/forget call also updates the
# Cognee/Kuzu knowledge graph. Best-effort — memu-core never blocks on it.
# Set false if memu-graph is not running (e.g. minimal stack).
FF_GRAPH_INGEST=true

# ── Letta agent memory controller ────────────────────────────────────
# URL of the letta-agent service (only used when FF_LETTA_TASKS=true)
LETTA_URL=http://letta-agent:8062
# Delegate long-running / research tasks to letta-agent's memory controller.
# Keep false until verified on GPU; adds a 30s round-trip on every request.
FF_LETTA_TASKS=false
# After each Letta run, sync new archival memories back into memu-core
# (category="letta_archival") so the vector index stays current.
FF_LETTA_MEMORY_SYNC=false

[run]
source = common/,agentic/,memu-core/,letta-agent/,financial-awareness/
concurrency = thread
omit =
    */test_*
    */_archive/*
    */.venv/*
    */migrations/*

[report]
show_missing = true
fail_under = 60
exclude_lines =
    pragma: no cover
    if __name__ == .__main__
    raise NotImplementedError
    pass

[html]
directory = output/coverage_html
